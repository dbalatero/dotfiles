#!/usr/bin/env bash

function dotsay() {
  local result=$(_colorized $@)
  echo "$result"
}

function print_action() {
  dotsay "@b@blue[[+ $1]]"
}

function _colorized() {
   echo "$@" | sed -E \
     -e 's/((@(red|green|yellow|blue|magenta|cyan|white|reset|b|u))+)[[]{2}(.*)[]]{2}/\1\4@reset/g' \
     -e "s/@red/$(tput setaf 1)/g" \
     -e "s/@green/$(tput setaf 2)/g" \
     -e "s/@yellow/$(tput setaf 3)/g" \
     -e "s/@blue/$(tput setaf 4)/g" \
     -e "s/@magenta/$(tput setaf 5)/g" \
     -e "s/@cyan/$(tput setaf 6)/g" \
     -e "s/@white/$(tput setaf 7)/g" \
     -e "s/@reset/$(tput sgr0)/g" \
     -e "s/@b/$(tput bold)/g" \
     -e "s/@u/$(tput sgr 0 1)/g"
}

function command_exists() {
  local name=$1

  command -v "$name" >/dev/null 2>&1
}

function require_gh() {
  if ! command_exists "gh"; then
    print_action "[prereq] Installing FZF"
    brew install gh
  fi
}

# function ensure_gh_is_logged_in() {
#   # TODO
# }

function require_fzf() {
  if ! command_exists "fzf"; then
    print_action "[prereq] Installing FZF"
    brew install fzf
  fi
}

function pr_switch() {
  require_fzf
  require_gh
  # ensure_gh_is_logged_in

  local pull_requests=$(gh pr list --author "@me" --json state,title,url)

  if [ "$pull_requests" = "[]" ]; then
    echo "You have no open PRs in this repo."
    exit 0
  fi
}

# https://sookocheff.com/post/bash/parsing-bash-script-arguments-with-shopts/
subcommand=$1; shift

case "$subcommand" in
  pr)
    pr_command=$1; shift

    case "$pr_command" in
      switch)
        pr_switch
        ;;
      *)
        dotsay "Unknown $(dotsay "@cyan[[work pr]]") subcommand: $(dotsay "@yellow[[$pr_command]]")"
        exit 1
        ;;
    esac
    ;;
  *)
    echo "Unknown subcommand: $subcommand"
    exit 1
    ;;
esac

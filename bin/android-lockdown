function remove_google_apps() {
  local packages=(
    com.google.android.apps.docs
    com.google.android.apps.maps
    com.google.android.apps.photos
    com.google.android.apps.tachyon
    com.google.android.apps.wellbeing
    com.google.android.feedback
    com.google.android.googlequicksearchbox
    com.google.android.inputmethod.latin
    com.google.android.marvin.talkback
    com.google.android.music
    com.google.android.printservice.recommendation
    com.google.android.syncadapters.calendar
    com.google.android.tts
    com.google.android.videos
    com.google.android.youtube
    com.google.ar.lens
  )

  for pkg in "${packages[@]}"
  do
    remove_package "$pkg"
  done
}

function remove_facebook() {
  local packages=(
    com.facebook.appmanager
    com.facebook.katana
    com.facebook.system
    com.facebook.services
  )

  for pkg in "${packages[@]}"
  do
    remove_package "$pkg"
  done
}

adb_installed
adb_connected

readonly CMD=$1
shift

case "${CMD}" in
  list)
    adb shell pm list packages
    ;;
  disable)
    echo "Disabling all packages"
    remove_samsung_print_services
    remove_samsung_pay
    remove_facebook
    remove_google_apps
    remove_microsoft_shit
    remove_samsung_bixby
    remove_samsung_browser
    remove_samsung_car_mode
    remove_samsung_dex
    remove_samsung_email
    remove_samsung_game_launcher
    remove_samsung_random_shit
    remove_samsung_store_bloat
    ;;
  *)
    print_usage
    ;;
esac
